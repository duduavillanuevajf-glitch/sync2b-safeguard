# ─── APPLICATION ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v2
FRONTEND_URL=http://localhost
# CORS_ORIGINS: origens permitidas separadas por vírgula.
# IP local:      http://192.168.2.69
# Produção:      https://vault.empresa.com
# Multi-env:     https://vault.empresa.com,https://staging.empresa.com
CORS_ORIGINS=http://localhost

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://safeguard:secret@localhost:5432/safeguard
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
# Read replica (optional, falls back to primary)
DATABASE_URL_READONLY=

# ─── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_CHARS_HEX
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHARS_HEX
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=sync2b-safeguard
JWT_AUDIENCE=sync2b-safeguard-api

# ─── ENCRYPTION ────────────────────────────────────────────────────────────────
# Must be 64 hex chars (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
ENCRYPTION_KEY_VERSION=1

# ─── HASHICORP VAULT (optional — falls back to env vars) ───────────────────────
VAULT_ENABLED=false
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_KV_MOUNT=secret
VAULT_KV_PATH=safeguard

# ─── EMAIL (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_API_KEY_HERE
EMAIL_FROM=Sync2B Safeguard <noreply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# ─── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_IMPORT_MAX=5

# ─── SECURITY ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
TOTP_WINDOW=2
PASSWORD_RESET_TTL_MINUTES=15

# ─── JOBS ──────────────────────────────────────────────────────────────────────
JOBS_ENABLED=true
EXPIRY_ALERT_CRON=0 8 * * *
TOKEN_CLEANUP_CRON=0 3 * * *
DEFAULT_ALERT_DAYS=90

# ─── OBSERVABILITY ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
CORRELATION_ID_HEADER=X-Request-ID
